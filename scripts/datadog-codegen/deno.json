{
  "tasks": {
    "generate": "deno run --allow-net --allow-read --allow-write --allow-env --allow-run main.ts",
    "generate:dry-run": "deno run --allow-net --allow-read --allow-write --allow-env main.ts --dry-run",
    "check": "deno check *.ts lib/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "imports": {
    "@std/path": "jsr:@std/path@1",
    "@std/fs": "jsr:@std/fs@1",
    "@std/assert": "jsr:@std/assert@1",
    "@std/yaml": "jsr:@std/yaml@1"
  }
}
