{
  "tasks": {
    "check": "deno check extensions/models/provisioner.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "test": "deno test --allow-env --allow-read --allow-write --allow-run",
    "fmt:check": "deno fmt --check"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-import-prefix"
      ]
    }
  },
  "compilerOptions": {
    "strict": true
  }
}
